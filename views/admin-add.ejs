<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Item — ShopShow Admin</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-layout">

  <nav class="admin-nav">
    <div class="brand">Shop<span>Show</span> <span style="font-family:var(--ff-mono);font-size:0.65rem;opacity:0.5;font-weight:400;margin-left:0.4rem;">ADMIN</span></div>
    <div class="admin-nav-links">
      <a href="/admin">Dashboard</a>
      <a href="/admin/add" class="active">+ Add Item</a>
      <a href="/" target="_blank">View Site ↗</a>
      <a href="/admin/logout">Sign Out</a>
    </div>
  </nav>

  <main class="admin-main">
    <div class="page-title">Add New Item</div>
    <div class="page-subtitle">Fill in the details to create a new product listing</div>

    <% if (error) { %>
      <div class="alert alert-error" style="max-width:680px;margin-bottom:1.5rem;"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success" style="max-width:680px;margin-bottom:1.5rem;"><%= success %> <a href="/admin">← Back to dashboard</a></div>
    <% } %>

    <div class="form-card animate-in">
      <form action="/admin/add" method="POST" enctype="multipart/form-data">

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="title">Product Title *</label>
            <input type="text" id="title" name="title" class="form-input" placeholder="e.g. Handmade Leather Wallet" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="price">Price (₹) *</label>
            <input type="number" id="price" name="price" class="form-input" placeholder="e.g. 999" min="0" step="0.01" required>
          </div>
        </div>

        <div class="form-group" style="margin-bottom:1.2rem;">
          <label class="form-label" for="category">Category</label>
          <input type="text" id="category" name="category" class="form-input" placeholder="e.g. Accessories, Electronics, Fashion…">
        </div>

        <div class="form-group" style="margin-bottom:1.2rem;">
          <label class="form-label" for="description">Description</label>
          <textarea id="description" name="description" class="form-textarea" placeholder="Describe the product — materials, features, size, condition…"></textarea>
        </div>

        <div class="form-group" style="margin-bottom:1.5rem;">
          <label class="form-label">Product Image *</label>
          <div class="upload-zone">
            <input type="file" id="imageInput" name="image" accept="image/*" required>
            <div class="upload-icon">📷</div>
            <p><strong>Click to upload</strong> or drag and drop</p>
            <p style="margin-top:0.3rem;font-size:0.78rem;">PNG, JPG, WEBP up to 10MB</p>
          </div>
          <img id="imagePreview" src="" alt="Preview" class="current-img" style="display:none;margin-top:0.75rem;">
        </div>

        <div class="form-actions">
          <a href="/admin" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary-form">Publish Item</button>
        </div>
      </form>
    </div>
  </main>
</div>
<script src="/js/main.js"></script>
</body>
</html>
