<%
  const itemUrl = (typeof process !== 'undefined') ? '' : '';
  const fullUrl = '{{ITEM_URL}}';
  const allImages = (item.images && item.images.length) ? item.images : (item.image ? [item.image] : []);
%>
<%- include('partials/header', {
  title: item.title,
  metaDesc: item.description || 'View and share this product on ShopShow.',
  ogTitle: item.title,
  ogDesc: item.description,
  ogImage: item.image
}) %>

<nav class="navbar">
  <a href="/" class="nav-brand">Shop<span>Show</span></a>
  <div class="nav-links">
    <a href="/">← All Products</a>
  </div>
</nav>

<a href="/" class="back-link">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
  Back to all products
</a>

<section class="item-detail animate-in">

  <!-- Image Gallery -->
  <div class="item-img-wrap" style="display:flex;flex-direction:column;gap:12px;">

    <!-- Main large image -->
    <div style="position:relative;overflow:hidden;border-radius:12px;background:#111;aspect-ratio:4/3;">
      <img id="mainImage"
        src="<%= allImages[0] %>"
        alt="<%= item.title %>"
        style="width:100%;height:100%;object-fit:contain;border-radius:12px;transition:opacity 0.2s ease;"
      >
      <% if (allImages.length > 1) { %>
      <!-- Prev / Next arrows -->
      <button onclick="changeImage(-1)" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:36px;height:36px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2;">‹</button>
      <button onclick="changeImage(1)"  style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:36px;height:36px;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:2;">›</button>
      <!-- Image counter -->
      <div id="imgCounter" style="position:absolute;bottom:10px;right:12px;background:rgba(0,0,0,0.6);color:#eee;font-size:0.72rem;padding:3px 9px;border-radius:20px;">1 / <%= allImages.length %></div>
      <% } %>
    </div>

    <!-- Thumbnail strip (only if more than 1 image) -->
    <% if (allImages.length > 1) { %>
    <div id="thumbStrip" style="display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;">
      <% allImages.forEach((img, idx) => { %>
        <img
          src="<%= img %>"
          alt="Photo <%= idx + 1 %>"
          onclick="setImage(<%= idx %>)"
          id="thumb-<%= idx %>"
          style="width:72px;height:72px;object-fit:cover;border-radius:8px;cursor:pointer;flex-shrink:0;border:2px solid <%= idx === 0 ? '#d4af37' : 'transparent' %>;opacity:<%= idx === 0 ? '1' : '0.6' %>;transition:all 0.2s;"
        >
      <% }) %>
    </div>
    <% } %>

  </div>

  <!-- Info -->
  <div class="item-info">
    <span class="category-tag">✦ <%= item.category || 'General' %></span>
    <h1><%= item.title %></h1>
    <div class="item-price">KD <%= parseFloat(item.price).toLocaleString('en-KW') %></div>

    <!-- Quantity & Shipping Info -->
    <div style="display:flex;flex-wrap:wrap;gap:10px;margin:0.8rem 0 1rem;">
      <span style="background:#1a1a2e;border:1px solid #d4af37;color:#d4af37;padding:6px 14px;border-radius:20px;font-size:0.82rem;font-weight:600;">
        📦 <%= item.quantity || 1 %> item<%= (item.quantity || 1) > 1 ? 's' : '' %> available
      </span>
      <span style="background:#0d2b1f;border:1px solid #25D366;color:#25D366;padding:6px 14px;border-radius:20px;font-size:0.82rem;font-weight:600;">
        🚚 Free shipping to your address
      </span>
    </div>

    <p class="item-desc"><%= item.description || 'No description provided.' %></p>

    <!-- Order via WhatsApp -->
    <div class="share-actions">
      <p>Order this product</p>
      <div class="share-actions-row">
        <button class="share-pill sp-wa" onclick="orderOnWhatsApp('<%= item.title.replace(/'/g, "\\'") %>')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:6px;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Order on WhatsApp
        </button>
      </div>
    </div>

    <p class="item-date">Listed on <%= new Date(item.createdAt).toLocaleDateString('en-KW', { year:'numeric', month:'long', day:'numeric' }) %></p>
  </div>
</section>

<script>
  var images = <%- JSON.stringify(allImages) %>;
  var current = 0;

  function setImage(idx) {
    current = idx;
    var mainImg = document.getElementById('mainImage');
    mainImg.style.opacity = '0';
    setTimeout(function() {
      mainImg.src = images[idx];
      mainImg.style.opacity = '1';
    }, 150);
    var counter = document.getElementById('imgCounter');
    if (counter) counter.textContent = (idx + 1) + ' / ' + images.length;
    // Update thumbnails
    images.forEach(function(_, i) {
      var thumb = document.getElementById('thumb-' + i);
      if (thumb) {
        thumb.style.border = i === idx ? '2px solid #d4af37' : '2px solid transparent';
        thumb.style.opacity = i === idx ? '1' : '0.6';
      }
    });
  }

  function changeImage(dir) {
    var next = (current + dir + images.length) % images.length;
    setImage(next);
  }

  // Swipe support for mobile
  var touchStartX = 0;
  var mainImg = document.getElementById('mainImage');
  if (mainImg) {
    mainImg.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; });
    mainImg.addEventListener('touchend', function(e) {
      var diff = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) changeImage(diff > 0 ? 1 : -1);
    });
  }

  function orderOnWhatsApp(itemTitle) {
    var message = encodeURIComponent('Hi! I would like to place an order for: ' + itemTitle);
    window.open('https://wa.me/96541201907?text=' + message, '_blank');
  }
</script>

<%- include('partials/footer') %>
