<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Item — ShopShow Admin</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .current-imgs-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 10px;
      margin-bottom: 12px;
    }
    .current-imgs-grid img {
      width: 100%;
      height: 100px;
      object-fit: cover;
      border-radius: 8px;
      border: 2px solid var(--border);
    }
    .current-imgs-grid img:first-child {
      border-color: #d4af37;
    }
    .img-preview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
      gap: 10px;
      margin-top: 12px;
    }
    .img-preview-grid img {
      width: 100%;
      height: 100px;
      object-fit: cover;
      border-radius: 8px;
      border: 2px solid var(--border);
    }
    .img-count-note {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 6px;
    }
  </style>
</head>
<body>
<div class="admin-layout">

  <nav class="admin-nav">
    <div class="brand">Shop<span>Show</span> <span style="font-family:var(--ff-mono);font-size:0.65rem;opacity:0.5;font-weight:400;margin-left:0.4rem;">ADMIN</span></div>
    <div class="admin-nav-links">
      <a href="/admin">Dashboard</a>
      <a href="/admin/add">+ Add Item</a>
      <a href="/" target="_blank">View Site ↗</a>
      <a href="/admin/logout">Sign Out</a>
    </div>
  </nav>

  <main class="admin-main">
    <div class="page-title">Edit Item</div>
    <div class="page-subtitle">Update the details for "<%= item.title %>"</div>

    <% if (error) { %>
      <div class="alert alert-error" style="max-width:680px;margin-bottom:1.5rem;"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success" style="max-width:680px;margin-bottom:1.5rem;"><%= success %> <a href="/admin">← Back to dashboard</a></div>
    <% } %>

    <div class="form-card animate-in">
      <form action="/admin/edit/<%= item.id %>" method="POST" enctype="multipart/form-data">

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="title">Product Title *</label>
            <input type="text" id="title" name="title" class="form-input" value="<%= item.title %>" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="price">Price (KD) *</label>
            <input type="number" id="price" name="price" class="form-input" value="<%= item.price %>" min="0" step="0.01" required>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="quantity">Available Quantity *</label>
            <input type="number" id="quantity" name="quantity" class="form-input" value="<%= item.quantity || 1 %>" min="1" step="1" required>
          </div>
          <div class="form-group">
            <label class="form-label" for="category">Category</label>
            <input type="text" id="category" name="category" class="form-input" value="<%= item.category || '' %>" placeholder="e.g. Accessories, Electronics…">
          </div>
        </div>

        <div class="form-group" style="margin-bottom:1.2rem;">
          <label class="form-label" for="description">Description</label>
          <textarea id="description" name="description" class="form-textarea"><%= item.description || '' %></textarea>
        </div>

        <div class="form-group" style="margin-bottom:1.5rem;">
          <label class="form-label">Product Images <span style="font-weight:400;color:var(--muted);">(up to 8 photos)</span></label>

          <% const allImgs = item.images && item.images.length ? item.images : (item.image ? [item.image] : []); %>
          <% if (allImgs.length > 0) { %>
            <p style="font-size:0.78rem;color:var(--muted);margin-bottom:0.5rem;">Current photos <span style="color:#d4af37;">(gold border = cover photo)</span>:</p>
            <div class="current-imgs-grid">
              <% allImgs.forEach(img => { %>
                <img src="<%= img %>" alt="Product photo">
              <% }) %>
            </div>
          <% } %>

          <div class="upload-zone" onclick="document.getElementById('imageInput').click()">
            <input type="file" id="imageInput" name="images" accept="image/*" multiple style="display:none;">
            <div class="upload-icon">🔄</div>
            <p><strong>Click to replace all photos</strong> or leave blank to keep current</p>
            <p style="margin-top:0.3rem;font-size:0.78rem;">Select multiple photos at once — PNG, JPG, WEBP up to 10MB each</p>
          </div>
          <div id="previewGrid" class="img-preview-grid"></div>
          <p class="img-count-note" id="imgCountNote"></p>
        </div>

        <div class="form-actions">
          <a href="/admin" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary-form">Save Changes</button>
        </div>
      </form>
    </div>
  </main>
</div>

<script>
  document.getElementById('imageInput').addEventListener('change', function() {
    const grid = document.getElementById('previewGrid');
    const note = document.getElementById('imgCountNote');
    grid.innerHTML = '';
    const files = Array.from(this.files).slice(0, 8);
    files.forEach((file, idx) => {
      const reader = new FileReader();
      reader.onload = e => {
        const img = document.createElement('img');
        img.src = e.target.result;
        img.title = idx === 0 ? 'Cover photo' : 'Photo ' + (idx + 1);
        grid.appendChild(img);
      };
      reader.readAsDataURL(file);
    });
    note.textContent = files.length + ' new photo' + (files.length !== 1 ? 's' : '') + ' selected — will replace all current photos';
  });
</script>
</body>
</html>
