<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — ShopShow</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔐</text></svg>">
</head>
<body>
<div class="admin-login-page">
  <div class="login-card animate-in">
    <div class="brand">Shop<span>Show</span></div>
    <div class="tagline">admin portal</div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/admin/login" method="POST">
      <div class="form-group">
        <label class="form-label" for="username">Admin ID</label>
        <input
          type="text"
          id="username"
          name="username"
          class="form-input"
          placeholder="Enter your admin ID"
          autocomplete="username"
          required
          autofocus
        >
      </div>
      <div class="form-group">
        <label class="form-label" for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          class="form-input"
          placeholder="••••••••"
          autocomplete="current-password"
          required
        >
      </div>
      <button type="submit" class="btn-primary">Sign in to Admin Panel</button>
    </form>

    <p style="margin-top:1.5rem;font-size:0.78rem;color:var(--muted);text-align:center;">
      <a href="/" style="color:var(--muted);text-decoration:underline;">← Back to public site</a>
    </p>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
