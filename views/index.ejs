<%- include('partials/header', {
  title: 'Discover Products',
  metaDesc: 'Browse and share amazing products on ShopShow.',
  ogTitle: 'ShopShow — Discover & Share Products'
}) %>

<!-- Navbar -->
<nav class="navbar">
  <a href="/" class="nav-brand">Shop<span>Show</span></a>
  <div class="nav-links">
    <span class="nav-count" id="visibleCount"><%= items.length %> items</span>
  </div>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-content">
    <span class="hero-eyebrow">✦ curated collection</span>
    <h1>Discover &amp; Share <em>Beautiful</em> Things</h1>
    <p>Browse our carefully curated products and share your favourites with friends instantly.</p>
  </div>
</section>

<!-- Search & Filter -->
<div class="section-header">
  <h2>All Products</h2>
  <span class="count-badge" id="visibleCount"><%= items.length %> items</span>
</div>

<div class="filter-bar">
  <div class="search-wrap">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input
      type="text"
      class="search-input"
      id="searchInput"
      placeholder="Search products…"
      autocomplete="off"
    >
  </div>
  <% const categories = [...new Set(items.map(i => i.category).filter(Boolean))]; %>
  <% if (categories.length > 1) { %>
  <select class="filter-select" id="filterCategory">
    <option value="">All categories</option>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.toLowerCase() %>"><%= cat %></option>
    <% }) %>
  </select>
  <% } %>
</div>

<!-- Grid -->
<main class="grid">
  <% if (items.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">🛍️</div>
      <h3>No products yet</h3>
      <p>The admin hasn't added any items yet. Check back soon!</p>
    </div>
  <% } else { %>
    <% items.forEach((item, idx) => { %>
      <article
        class="card"
        data-title="<%= item.title %>"
        data-desc="<%= item.description %>"
        data-cat="<%= (item.category || '').toLowerCase() %>"
        style="animation-delay: <%= (idx * 0.07).toFixed(2) %>s"
      >
        <a href="/item/<%= item.id %>" class="card-img-wrap">
          <img
            src="<%= item.image %>"
            alt="<%= item.title %>"
            loading="<%= idx < 4 ? 'eager' : 'lazy' %>"
          >
          <span class="card-category"><%= item.category || 'General' %></span>
        </a>
        <div class="card-body">
          <h3 class="card-title"><%= item.title %></h3>
          <p class="card-desc"><%= item.description || 'No description provided.' %></p>
        </div>
        <div class="card-footer">
          <div class="card-price">
            <span>₹</span><%= parseFloat(item.price).toLocaleString('en-IN') %>
          </div>
          <div style="display:flex;gap:0.5rem;">
            <a href="/item/<%= item.id %>" class="view-btn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              View
            </a>
            <button class="share-btn whatsapp-order-btn" onclick="orderOnWhatsApp('<%= item.title.replace(/'/g, "\\'") %>')">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Order
            </button>
          </div>
        </div>
      </article>
    <% }) %>
    <div class="empty-state" id="emptyState" style="display:none;">
      <div class="empty-icon">🔍</div>
      <h3>No results found</h3>
      <p>Try a different search term or category.</p>
    </div>
  <% } %>
</main>

<!-- WhatsApp Order Script -->
<script>
  function orderOnWhatsApp(itemTitle) {
    var message = encodeURIComponent('Hi! I would like to place an order for: ' + itemTitle);
    var waLink = 'https://wa.me/96541201907?text=' + message;
    window.open(waLink, '_blank');
  }

  // Search & filter logic (unchanged)
  const searchInput = document.getElementById('searchInput');
  const filterCategory = document.getElementById('filterCategory');
  const cards = document.querySelectorAll('.card');
  const emptyState = document.getElementById('emptyState');
  const visibleCounts = document.querySelectorAll('#visibleCount');

  function updateVisible() {
    const query = searchInput ? searchInput.value.toLowerCase() : '';
    const cat = filterCategory ? filterCategory.value.toLowerCase() : '';
    let visible = 0;
    cards.forEach(card => {
      const title = (card.dataset.title || '').toLowerCase();
      const desc = (card.dataset.desc || '').toLowerCase();
      const cardCat = (card.dataset.cat || '').toLowerCase();
      const matchesSearch = !query || title.includes(query) || desc.includes(query);
      const matchesCat = !cat || cardCat === cat;
      if (matchesSearch && matchesCat) {
        card.style.display = '';
        visible++;
      } else {
        card.style.display = 'none';
      }
    });
    if (emptyState) emptyState.style.display = visible === 0 ? 'flex' : 'none';
    visibleCounts.forEach(el => el.textContent = visible + ' items');
  }

  if (searchInput) searchInput.addEventListener('input', updateVisible);
  if (filterCategory) filterCategory.addEventListener('change', updateVisible);
</script>

<!-- WhatsApp Order Button Style -->
<style>
  .whatsapp-order-btn {
    background: #25D366 !important;
    color: #fff !important;
    border-color: #25D366 !important;
  }
  .whatsapp-order-btn:hover {
    background: #1ebe5d !important;
    border-color: #1ebe5d !important;
  }
</style>

<%- include('partials/footer') %>
